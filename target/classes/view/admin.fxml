<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="employeedata.controller.AdminController">
    <Label text="Admin Dashboard" style="-fx-font-size: 20;"/>
    <TextField fx:id="empidSearchField" promptText="Search by EmpID"/>
    <Button text="Search" onAction="#handleSearch"/>
    <TextArea fx:id="resultArea" prefHeight="200"/>
</VBox>